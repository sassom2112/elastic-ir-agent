# ── Elastic Cloud Serverless ──────────────────────────────────────────────────
# Get these from: cloud.elastic.co → your project → Connection details
ELASTIC_CLOUD_ID=your_cloud_id_here
ELASTIC_API_KEY=your_api_key_here
ELASTIC_INDEX_EVENTS=ir-events
ELASTIC_INDEX_MEMORY=ir-agent-memory

# Kibana URL for deploying ES|QL tools (shown in Kibana address bar)
# e.g. https://abc123.kb.us-central1.gcp.elastic-cloud.com
KIBANA_URL=https://your-project.kb.region.gcp.elastic-cloud.com

# Elastic Agent Builder MCP endpoint (shown in Kibana → Search → Agent Builder → Tools)
ELASTIC_MCP_ENDPOINT=https://your-project.es.region.gcp.elastic-cloud.com

# ── Google AI ─────────────────────────────────────────────────────────────────
# For local agent (free): aistudio.google.com → Get API key
GOOGLE_API_KEY=your_google_api_key_here

# For GCP Agent Builder deployment (requires GCP project)
GOOGLE_PROJECT_ID=your_gcp_project_id
GOOGLE_REGION=us-central1

# Resource ID of the deployed GCP agent (set after running create_gcp_agent.py)
GCP_AGENT_ID=
