# ── Elastic Cloud Serverless ──────────────────────────────────────────────────
# ELASTIC_URL: the Elasticsearch endpoint shown on the Getting Started page
#   e.g. https://my-elasticsearch-project-e92c2abc.es.us-east-1.aws.elastic.cloud
ELASTIC_URL=https://your-project.es.region.provider.elastic.cloud

# Scoped API keys (recommended):
#   ELASTIC_API_KEY_READ  — read-only, scoped to ir-events + ir-agent-memory
#   ELASTIC_API_KEY_WRITE — write, scoped to ir-agent-memory only
# Both fall back to ELASTIC_API_KEY if not set (fine for local dev).
ELASTIC_API_KEY_READ=your_read_only_api_key_here
ELASTIC_API_KEY_WRITE=your_write_api_key_here

# Single key fallback (local dev / quick start):
ELASTIC_API_KEY=your_api_key_here
ELASTIC_INDEX_EVENTS=ir-events
ELASTIC_INDEX_MEMORY=ir-agent-memory

# Kibana URL — same host, replace .es. with .kb.
KIBANA_URL=https://your-project.kb.region.provider.elastic.cloud

# Elastic Agent Builder MCP endpoint (Kibana → Search → Agent Builder → Tools)
# Usually the same as ELASTIC_URL
ELASTIC_MCP_ENDPOINT=https://your-project.es.region.provider.elastic.cloud

# ── Google AI ─────────────────────────────────────────────────────────────────
# For local agent (free): aistudio.google.com → Get API key
GOOGLE_API_KEY=your_google_api_key_here

# For GCP Agent Builder deployment (requires GCP project)
GOOGLE_PROJECT_ID=your_gcp_project_id
GOOGLE_REGION=us-central1

# Resource ID of the deployed GCP agent (set after running create_gcp_agent.py)
GCP_AGENT_ID=
